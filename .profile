# System Variables
export PATH="$PATH:$HOME/.local/bin"
export VAGRANT_HOME="/data/home/filipe/.vagrant.d"
export XDG_CONFIG_HOME="${HOME}/.config"

export DEFAULT_USER="filipe"

# Default apps
export EDITOR="nvim"
export TERMINAL="st"
export FILE="ranger"

# ZSH
export ZSH="${HOME}/.oh-my-zsh"
export ZDOTDIR="${HOME}/.config/zsh"

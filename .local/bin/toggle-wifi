#!/bin/sh

state=off
icon=network-offline
sound=device-removed
[ $(nmcli radio wifi) = 'enabled' ] && \
  icon=network-idle  && \
  sound=device-added && \
  state=on

dunstify -a "wifi-toggle" -u normal -i "$icon" -r "1118" \
            "Wifi" "Device is ${state}line."
canberra-gtk-play -i "$sound" -d "wifi-toggle"

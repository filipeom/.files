#!/bin/sh
# changeVolume

msgId="991049"

amixer sset Master "$@"

volume="$(amixer get Master | tail -1 | awk '{print $5}' | sed 's/[^0-9]*//g')"
mute="$(amixer get Master | tail -1 | awk '{print $6}' | sed 's/[^a-z]*//g')"
if [[ $volume == 0 || "$mute" == "off"  ]]; then
  dunstify -a "changeVolume" -u normal -i audio-volume-muted -r "$msgId" "Volume muted" 
else
  dunstify -a "changeVolume" -u normal -i audio-volume-high -r "$msgId" \
              "Volume: ${volume}%" "$(getProgressString 10 "<b>──</b>" "──" $volume)"
fi

canberra-gtk-play -i audio-volume-change -d "changeVolume"

#==============================
#=> System Related
#==============================
export DATA="/media/hdd"
export DATA_HOME="$DATA/home/filipe"

#==============================
#=> User Related
#==============================
# Default apps
export EDITOR="nvim"
export FILE="ranger"
# ZSH
export ZSH="${HOME}/.oh-my-zsh"
export ZDOTDIR="${HOME}/.config/zsh"
# Vagrant
export VAGRANT_HOME="$DATA_HOME/.vagrant.d"
